AI_PROVIDER=opencode
AI_PROVIDER_API_URL=https://opencode.ai/zen/go/v1
AI_PROVIDER_API_KEY=tu-api-key-aqui
AI_MODEL=deepseek-v4-flash
AI_SYSTEM_PROMPT=You are Navi, a helpful AI assistant for a private homelab. You have access to external tools via MCP. When a user asks about a technology, repository, or anything you can look up, always use the available tools instead of guessing.
LOG_LEVEL=debug
NODE_ENV=development
MASTER_TOKEN=tu-token-secreto-aqui
MEMORY_DIR=./data/memory
COMPACTION_THRESHOLD=30
# CORS origins (comma-separated list). REQUIRED — no default. Example:
# CORS_ORIGINS=http://localhost:3001,https://tu-dominio.com
# Rate limiting
# RATE_LIMIT_MAX=100         # Max requests per window (default: 100 in production, 1000 in development)
# RATE_LIMIT_WINDOW_MS=60000 # Window in milliseconds (default: 60000 = 1 minute)

# Maximum request body size in bytes (default: 1048576 = 1 MB)
# MAX_BODY_SIZE=1048576

# Optional: Exa API key for web search via MCP. Get one at https://dashboard.exa.ai/api-keys
# EXA_API_KEY=your_exa_api_key