# Navi Docker Compose - Variables de entorno
# Copia este archivo como .env y ajusta los valores

# --- navi-core (obligatorias) ---
AI_PROVIDER=opencode
AI_PROVIDER_API_URL=https://opencode.ai/zen/go/v1
AI_PROVIDER_API_KEY=tu-api-key-aqui
AI_MODEL=deepseek-v4-flash
MASTER_TOKEN=tu-token-secreto-aqui

# --- navi-core (opcionales) ---
# AI_SYSTEM_PROMPT=
# LOG_LEVEL=info
# COMPACTION_THRESHOLD=30
# CORS_ORIGINS — required, comma-separated. Example: http://localhost:3001,https://tu-dominio.com
# EXA_API_KEY=

# --- body size limit ---
# MAX_BODY_SIZE=1048576

# --- rate limiting ---
# RATE_LIMIT_MAX=100
# RATE_LIMIT_WINDOW_MS=60000
